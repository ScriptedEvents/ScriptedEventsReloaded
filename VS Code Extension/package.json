{
  "name": "ser",
  "displayName": "Scripted Events Reloaded",
  "description": "Language support, hover documentation and contextual completions for SER scripts",
  "version": "1.5.7",
  "publisher": "ElektrykAndrzej",
  "main": "./out/extension.js",
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "activationEvents": [
    "onLanguage:ser"
  ],
  "categories": [
    "Programming Languages"
  ],
  "icon": "images/icon.png",
  "contributes": {
    "languages": [
      {
        "id": "ser",
        "aliases": [
          "SER",
          "ser"
        ],
        "extensions": [
          ".ser"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "dark": "images/icon.png",
          "light": "images/icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "ser",
        "scopeName": "source.txt",
        "path": "./syntaxes/ser.tmLanguage.json"
      }
    ]
  }
}
